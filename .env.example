# AudioFile — Environment Variables Template
# Copy to .env and fill in values

# Supabase Postgres connection string
DATABASE_URL=postgresql://postgres.bwzldaesynlruqukbnej:YOUR_DB_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require

# Supabase (used by Go backend auth middleware to verify tokens)
SUPABASE_URL=https://bwzldaesynlruqukbnej.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase browser config (injected into frontend at build time)
PUBLIC_SUPABASE_URL=https://bwzldaesynlruqukbnej.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Discogs API credentials (optional — enables Discogs search results)
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=

# Paddle Billing
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox
PADDLE_CLIENT_TOKEN=
PADDLE_PREMIUM_MONTHLY_PRICE_ID=pri_XXXX
APP_BASE_URL=https://audiofile.app

# Server config
HOST=0.0.0.0
PORT=8080
