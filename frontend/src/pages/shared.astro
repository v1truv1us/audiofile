---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Shared">
	<div class="space-y-8">
		<div class="border-b border-gold-muted/30 pb-6">
			<h1 class="font-serif text-4xl text-espresso font-normal mb-1">Shared with me</h1>
			<p class="text-gold-dark text-xs tracking-[0.12em] uppercase">Wishlists shared with you by other collectors</p>
		</div>
		<div id="shared-content"></div>
	</div>
</Layout>

<script>
	import { apiFetch } from '../lib/api';

	type WishlistItem = {
		id: string;
		title: string;
		artist: string;
		priority: number;
		targetPrice: number | null;
		notes: string;
		label: string;
	};

	type SharedWishlist = {
		owner: { id: string; username: string; displayName: string };
		items: WishlistItem[];
	};

	const container = document.getElementById('shared-content')!;

	function escapeHtml(s: string): string {
		return s
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;')
			.replace(/"/g, '&quot;');
	}

	function priorityLabel(p: number): string {
		return p <= 3 ? 'High' : p <= 6 ? 'Medium' : 'Low';
	}

	function priorityClass(p: number): string {
		return p <= 3 ? 'text-gold-dark' : 'text-gold-muted';
	}

	function themeColor(label: string): string {
		switch (label) {
			case 'Blue Note': return '#BA7517';
			case 'Impulse!': return '#534AB7';
			case 'Island': return '#0F6E56';
			case 'Capitol': return '#B5291E';
			case 'Columbia': return '#A0001C';
			case 'Verve': return '#1A3C6E';
			default: return '#854F0B';
		}
	}

	function renderItem(item: WishlistItem): string {
		const theme = themeColor(item.label);
		const pLabel = priorityLabel(item.priority);
		const pClass = priorityClass(item.priority);
		return `
			<div class="bg-white border border-gold/50 rounded-lg px-5 py-4 flex items-center gap-5 hover:border-gold transition-colors">
				<div class="w-10 h-10 flex-shrink-0">
					<svg width="40" height="40" viewBox="0 0 40 40" aria-hidden="true">
						<circle cx="20" cy="20" r="19" fill="#1a1a18" stroke="rgba(255,255,255,0.06)" stroke-width="0.5"/>
						<circle cx="20" cy="20" r="15" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="0.7"/>
						<circle cx="20" cy="20" r="11" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="0.7"/>
						<circle cx="20" cy="20" r="7" fill="${theme}"/>
						<circle cx="20" cy="20" r="1.5" fill="rgba(0,0,0,0.5)"/>
					</svg>
				</div>
				<div class="flex-1 min-w-0">
					<div class="font-serif text-sm text-espresso">${escapeHtml(item.title)}</div>
					<div class="text-[11px] text-gold-dark mt-0.5">${escapeHtml(item.artist)}</div>
					${item.notes ? `<div class="text-[10px] text-gold-muted mt-1 italic">${escapeHtml(item.notes)}</div>` : ''}
				</div>
				<div class="text-right flex-shrink-0">
					${item.targetPrice ? `<div class="text-xs font-medium text-espresso">$${item.targetPrice}</div>` : ''}
					<div class="text-[9px] tracking-[0.1em] uppercase mt-1 ${pClass}">${pLabel} priority</div>
				</div>
			</div>
		`;
	}

	function renderLoading() {
		container.innerHTML = '<div class="text-center py-12 text-gold-muted text-xs tracking-widest uppercase">Loading...</div>';
	}

	function renderEmpty() {
		container.innerHTML = `
			<div class="bg-espresso/5 border border-gold-muted/20 rounded-lg p-8 text-center">
				<div class="font-serif text-espresso text-lg mb-1">Nothing shared yet</div>
				<p class="text-gold-dark text-xs tracking-wide">No one has shared a wishlist with you yet.</p>
			</div>
		`;
	}

	function renderError(message: string) {
		container.innerHTML = `<p class="text-xs text-red-700">${escapeHtml(message)}</p>`;
	}

	function renderShared(shared: SharedWishlist[]) {
		if (shared.length === 0) {
			renderEmpty();
			return;
		}
		container.innerHTML = shared
			.map((group) => {
				const ownerName = group.owner.displayName || group.owner.username;
				return `
					<section class="mb-8">
						<div class="flex items-baseline gap-2 mb-3">
							<h2 class="font-serif text-xl text-espresso">${escapeHtml(ownerName)}</h2>
							<span class="text-[10px] text-gold-dark tracking-wide uppercase">@${escapeHtml(group.owner.username)}</span>
						</div>
						${
							group.items.length === 0
								? '<p class="text-xs text-gold-muted italic">No items in this wishlist.</p>'
								: `<div class="space-y-2">${group.items.map(renderItem).join('')}</div>`
						}
					</section>
				`;
			})
			.join('');
	}

	async function fetchShared() {
		renderLoading();
		try {
			const res = await apiFetch('/api/wishlist/shared-with-me');
			if (!res.ok) throw new Error(await res.text());
			const data: SharedWishlist[] = await res.json();
			renderShared(data);
		} catch (e) {
			renderError(e instanceof Error ? e.message : 'Failed to load shared wishlists');
		}
	}

	fetchShared();
</script>
