---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <title>{title} | CrateKeeper</title>
  </head>
  <body class="bg-neutral-950 text-neutral-100 min-h-screen">
    <nav class="border-b border-neutral-800 px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-lg font-bold tracking-tight text-amber-400">🎵 CrateKeeper</a>
      <div class="flex gap-6 text-sm">
        <a href="/collection" class="hover:text-amber-400 transition-colors">Collection</a>
        <a href="/wishlist" class="hover:text-amber-400 transition-colors">Wishlist</a>
      </div>
    </nav>
    <main class="px-4 py-6 max-w-5xl mx-auto">
      <slot />
    </main>
  </body>
</html>
